# Copy to .env and set values per deployment. Each school (School A, School B, etc.)
# uses their own .env on their server — no code changes; only environment variables.
#
# --- API Gateway (port 8000) ---
# SCHOOL_SERVICE_URL=http://localhost:8001
# DEVICE_SERVICE_URL=http://localhost:8002
# ATTENDANCE_SERVICE_URL=http://localhost:8003
# NOTIFICATION_SERVICE_URL=http://localhost:8004
# APP_BASE_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# NOTIFICATION_INTERNAL_KEY=
# SECRET_KEY=dev-secret-key-change-in-production
#
# When hosted, example for School A:
# SCHOOL_SERVICE_URL=http://school-service:8001
# DEVICE_SERVICE_URL=http://device-service:8002
# ATTENDANCE_SERVICE_URL=http://attendance-service:8003
# NOTIFICATION_SERVICE_URL=http://notification-service:8004
# APP_BASE_URL=https://app.school-a.com
# ALLOWED_ORIGINS=https://app.school-a.com
# NOTIFICATION_INTERNAL_KEY=<shared-secret-with-other-services>
# SECRET_KEY=<production-secret>
#
# --- School Service (port 8001) ---
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/school_biometric
# INTERNAL_API_KEY=<same-as-gateway-NOTIFICATION_INTERNAL_KEY>
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
#
# --- Device Service (port 8002) ---
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/school_biometric
# API_GATEWAY_URL=http://localhost:8000
# NOTIFICATION_INTERNAL_KEY=<same-as-gateway>
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Seconds within which a second tap is treated as accidental duplicate (not saved). After this, IN/OUT alternates (e.g. checkout after 2+ minutes).
# ATTENDANCE_ANTI_BOUNCE_SECONDS=90
#
# --- Attendance Service (port 8003) ---
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/school_biometric
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
#
# --- Notification Service (port 8004) ---
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
